  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "preview": {
      "compatibility_date": "2025-04-01",
      "compatibility_flags": [
        "nodejs_compat"
      ]
    },
    "production": {
      "compatibility_date": "2025-04-01",
      "compatibility_flags": [
        "nodejs_compat"
      ]
    }
  }
}
